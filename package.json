{
  "name": "ks2-spelling",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.18.0"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "postinstall": "node scripts/prepare-native-dependencies.mjs",
    "prepare:native-dependencies": "node scripts/prepare-native-dependencies.mjs",
    "build": "vite build",
    "lint": "oxlint src tests scripts vite.config.js",
    "test": "node --test tests/*.test.mjs",
    "test:default:no-android-resolution": "node --test --test-skip-pattern='^(default audit consumes the complete resolved Android certification|generated JSON and notices are byte-identical across repeated generation)$' tests/*.test.mjs",
    "test:android-resolved-policy": "node --test --test-name-pattern='^(default audit consumes the complete resolved Android certification|generated JSON and notices are byte-identical across repeated generation)$' tests/dependency-policy.test.mjs",
    "test:upstream:a3": "node --test vendor/ks2-mastery/tests/spelling-mobile-a3-*.test.js",
    "verify:vendor": "node scripts/verify-vendored-contract.mjs",
    "native:doctor": "node scripts/native-doctor.mjs",
    "native:sync:check": "node scripts/native-sync-check.mjs",
    "test:ios": "node scripts/test-ios.mjs",
    "test:android": "node scripts/test-android.mjs",
    "report:b2-native-plugins": "node scripts/build-b2-native-plugin-report.mjs",
    "report:b2-native-plugins:check": "node scripts/build-b2-native-plugin-report.mjs --check",
    "certify:android": "node scripts/certify-android-dependencies.mjs",
    "launch:ios": "node scripts/launch-ios-simulator.mjs",
    "launch:android": "node scripts/launch-android-emulator.mjs",
    "prove:b2:ios": "node scripts/prove-b2-ios.mjs",
    "prove:b2:android": "node scripts/prove-b2-android.mjs",
    "verify:b2": "npm run verify:vendor && npm run test:upstream:a3 && npm test && npm run lint && npm run build && npm run audit:dependencies && npm run native:sync:check && npm run test:ios && npm run test:android && node scripts/build-b2-exit-report.mjs --check",
    "audit:dependencies": "node scripts/audit-dependencies.mjs",
    "generate:notices": "node scripts/generate-third-party-notices.mjs"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor/android": "8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/ios": "8.4.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1",
    "@vitejs/plugin-react": "6.0.3",
    "oxlint": "1.71.0",
    "vite": "8.1.4"
  }
}
